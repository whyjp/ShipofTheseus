{
  "check_id": "scoring.correctness",
  "phase": "09",
  "grades": ["G2", "G3", "G4", "G5"],
  "status": "active",
  "producer": {
    "cmd_pattern": "^python .*measure_submission\\.py",
    "must_exit_zero": true
  },
  "provenance_required": ["tests_total", "tests_passed", "tests_failed", "intent_fidelity"],
  "assertions": [
    {
      "expr": "tests_total > 0",
      "on_fail": "no tests executed (no-work guard, rubric.md correctness — 설계 P1 _safe_div(default=1.0) 회귀 봉쇄)"
    },
    {
      "expr": "tests_passed <= tests_total",
      "on_fail": "tests_passed exceeds tests_total (impossible measurement)"
    },
    {
      "expr": "intent_fidelity == 1.0 or intent_fidelity == 0.7 or intent_fidelity == 0.0",
      "on_fail": "intent_fidelity not in {1.0, 0.7, 0.0} (invalid phase-09 Gate-1 result, rubric.md correctness)"
    }
  ],
  "value": "(tests_passed / tests_total) * intent_fidelity",
  "absence_policy": "FAIL"
}
